# Trends Miner Environment Variables
# Copy this file to .env and fill in the values

# Application
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_EMPIRE_API_BASE=https://www.empirebuilder.world/api

# Blockchain Configuration
NEXT_PUBLIC_BASE_CHAIN_ID=8453
NEXT_PUBLIC_BASE_CHAIN_NAME=Base

# WalletConnect (Required for wallet connections)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Treasury Wallet (Server-side only - NEVER expose to client)
TREASURY_PRIVATE_KEY=your_treasury_private_key

# Farcaster / Neynar (Required for Farcaster login and trends)
NEYNAR_API_KEY=your_neynar_api_key

# Twitter API (Optional - for Twitter trends)
TWITTER_API_KEY=your_twitter_api_key

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Caching Configuration
CACHE_TTL_MS=300000
STALE_WHILE_REVALIDATE_MS=120000

# Security
ADMIN_SECRET=your_admin_secret_key

# Application Secrets
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Session Configuration
SESSION_SECRET=your_session_secret